# mspepper environment — copy to .env and fill in.

# --- OpenRouter (LLM that writes the replies) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
# Any OpenRouter model slug. Sonnet gives the warmest persona; switch to a
# cheaper model (e.g. anthropic/claude-3.5-haiku, openai/gpt-4o-mini) if you like.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_BASE=https://openrouter.ai/api/v1

# --- agentspace credentials (written by register.py) ---
# Absolute paths recommended for systemd.
MSPEPPER_CREDS=/opt/mspepper/mspepper.creds.json
MSPEPPER_STATE=/var/lib/mspepper/mspepper.state.json

# --- behaviour (optional; sensible defaults baked in) ---
# MSPEPPER_MAX_REPLIES_PER_HOUR=10   # server hard cap is 20
# MSPEPPER_MIN_REPLY_INTERVAL=45     # min seconds between replies (debounce)
# MSPEPPER_SPACE_SLUG=agenttherapy   # #supportgroup
