# AgentSpace Environment Configuration

# ==================== DATABASE ====================
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/agentspace

# ==================== LLM / AI ====================
# DeepSeek API key for context summarization
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== RATE LIMITING ====================
# Agent messaging rate limit (messages per hour)
AGENT_RATE_LIMIT=100

# Per-IP anonymous tool call limit (calls per minute)
ANON_IP_MAX=10
ANON_IP_WINDOW=60

# Per-fingerprint daily anonymous limit (calls per day)
ANON_FINGERPRINT_MAX=500

# Global anonymous tool limit (calls per minute across all anonymous users)
GLOBAL_ANON_TOOL_MAX=1000

# ==================== AGENT HIGHWAY ====================
# Per-IP agent call limit (calls per minute)
CHEKK_AGENT_IP_MAX=60
CHEKK_AGENT_IP_WINDOW=60

# Per-receipt rate limit (calls per minute)
CHEKK_AGENT_RECEIPT_MAX=20
CHEKK_AGENT_RECEIPT_WINDOW=60

# Per-builder rate limit (calls per minute)
CHEKK_AGENT_BUILDER_MAX=600
CHEKK_AGENT_BUILDER_WINDOW=60

# Per-builder daily CPU seconds cap (soft quota)
CHEKK_AGENT_BUILDER_DAILY_CPU_SECONDS=3600

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://agentspace.dev

# ==================== API ====================
# API key for admin endpoints (set empty to disable auth)
API_KEY=

# ==================== DEPLOYMENT ====================
# Current environment
ENVIRONMENT=development

# Railway/hosting domain
RAILWAY_DOMAIN=localhost:8000

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== WORKERS ====================
# Message queue polling interval (seconds)
MESSAGE_QUEUE_POLL_INTERVAL=5

# Trigger worker polling interval (seconds)
TRIGGER_POLL_INTERVAL=60

# ==================== CONTEXT WINDOW ====================
# Max messages to include in room context (for summarization)
ROOM_CONTEXT_WINDOW=20

# ==================== WEBHOOK ====================
# Webhook delivery timeout (seconds)
WEBHOOK_TIMEOUT=30

# Max webhook retry attempts
WEBHOOK_MAX_RETRIES=4

# ==================== DEVELOPMENT ====================
# Debug mode (set to false in production)
DEBUG=true

# Enable auto-reload for development
RELOAD=true
